<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient"
    tools:context=".Presenter.Statistics">

    <!-- TODO: Update blank fragment layout -->
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <TextView
            android:id="@+id/in_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="10dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text=""
            android:textColor="@color/cardBg"
            android:textSize="@dimen/text_size_big"
            app:layout_constraintBottom_toTopOf="@+id/guideline4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/circle_success_click_area"
            android:layout_height="0dp"
            android:layout_width="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/circle_success_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_success_text"
            android:layout_marginTop="-15dp"
            android:layout_marginBottom="-15dp"
            />

        <ImageView
            android:id="@+id/circle_success"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:importantForAccessibility="no"
            android:src="@drawable/circle_success"
            app:layout_constraintTop_toTopOf="@+id/circle_success_text"
            app:layout_constraintEnd_toEndOf="@+id/circle_success_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_success_text"
            app:layout_constraintStart_toStartOf="@+id/circle_success_text" />

        <TextView
            android:id="@+id/circle_success_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/colorPrimary"
            android:layout_margin="30dp"
            android:padding="3dp"
            android:maxLines="1"
            app:autoSizeMaxTextSize="@dimen/text_size_giant"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintTop_toTopOf="@+id/guideline4"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/success_card"
            app:layout_constraintBottom_toTopOf="@+id/circle_blocked_text"
            app:layout_constraintWidth_max="100dp"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:id="@+id/success_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@+id/circle_success_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_success_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/circle_success_text"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:paddingTop="2dp"
                android:src="@drawable/ic_check_white_24dp" />

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"

                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sta_success"
                    android:textSize="@dimen/text_size_big" />

                <TextView
                    android:id="@+id/circle_success_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="@dimen/text_size_small" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/circle_blocked_click_area"
            android:layout_height="0dp"
            android:layout_width="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/circle_blocked_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_blocked_text"
            android:layout_marginTop="-15dp"
            android:layout_marginBottom="-15dp"
            />

        <ImageView
            android:id="@+id/circle_blocked"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:importantForAccessibility="no"
            android:src="@drawable/circle_blocked"
            app:layout_constraintTop_toTopOf="@+id/circle_blocked_text"
            app:layout_constraintEnd_toEndOf="@+id/circle_blocked_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_blocked_text"
            app:layout_constraintStart_toStartOf="@+id/circle_blocked_text" />

        <TextView
            android:id="@+id/circle_blocked_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/success"
            android:layout_margin="30dp"
            android:padding="3dp"
            android:maxLines="1"
            app:autoSizeMaxTextSize="@dimen/text_size_giant"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintTop_toBottomOf="@+id/circle_success_text"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/blocked_card"
            app:layout_constraintBottom_toTopOf="@+id/circle_failed_text"
            app:layout_constraintWidth_max="100dp"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:tools="http://schemas.android.com/tools"
            android:id="@+id/blocked_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@+id/circle_blocked_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_blocked_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/circle_blocked_text"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:paddingTop="4dp"
                android:src="@drawable/ic_block_color_24dp" />

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"

                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sta_blocked"
                    android:textColor="@color/active"
                    android:textSize="@dimen/text_size_big" />

                <TextView
                    android:id="@+id/circle_blocked_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/active"
                    android:textSize="@dimen/text_size_small" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/circle_failed_click_area"
            android:layout_height="0dp"
            android:layout_width="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/circle_failed_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_failed_text"
            android:layout_marginTop="-15dp"
            android:layout_marginBottom="-15dp"
            />

        <ImageView
            android:id="@+id/circle_failed"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:importantForAccessibility="no"
            android:src="@drawable/circle_fail"
            app:layout_constraintTop_toTopOf="@+id/circle_failed_text"
            app:layout_constraintEnd_toEndOf="@+id/circle_failed_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_failed_text"
            app:layout_constraintStart_toStartOf="@+id/circle_failed_text" />

        <TextView
            android:id="@+id/circle_failed_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/success"
            android:layout_margin="30dp"
            android:padding="3dp"
            android:maxLines="1"
            app:autoSizeMaxTextSize="@dimen/text_size_giant"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintTop_toBottomOf="@+id/circle_blocked_text"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/blocked_card"
            app:layout_constraintBottom_toTopOf="@+id/failed_note"
            app:layout_constraintWidth_max="100dp"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:tools="http://schemas.android.com/tools"
            android:id="@+id/failed_card"
            app:layout_constraintTop_toTopOf="@+id/circle_failed_text"
            app:layout_constraintBottom_toBottomOf="@+id/circle_failed_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/circle_failed_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:paddingTop="2dp"
                android:src="@drawable/ic_clear_color_24dp" />

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sta_failed"
                    android:textColor="@color/cardBg"
                    android:textSize="@dimen/text_size_big" />

                <TextView
                    android:id="@+id/circle_failed_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/cardBg"
                    android:textSize="@dimen/text_size_small" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:tools="http://schemas.android.com/tools"
            android:id="@+id/failed_note"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/guideline3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginLeft="50dp"
            android:layout_marginRight="50dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/ic_info_white_24dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/note_for_fail"
                android:textColor="@color/cardBg"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_reset_counter"
            style="@style/AppTheme.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:text="@string/reset_statistics"
            android:textSize="@dimen/text_size_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.85" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.10" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>